# ============================================================
# PricePulse Analytics — Environment Variables (TEMPLATE)
# ============================================================
# Copia este archivo como .env y configura tus valores:
#   cp .env.example .env
#
# Para Docker, usa .env.docker:
#   cp .env.docker .env && docker compose up
#
# En Streamlit Cloud NO necesitas este archivo — configura los
# secrets desde la UI de Streamlit Cloud (Settings → Secrets).
# ============================================================

# --- Base de Datos ---
# SQLite (default — 0 configuración, ideal para Streamlit Cloud):
DATABASE_URL=sqlite:///data/pricepulse.db

# PostgreSQL (para producción en VPS — descomenta y comenta la línea SQLite):
# DATABASE_URL=postgresql+psycopg2://pricepulse_user:change_me_secure_password@localhost:5432/pricepulse

# Variables individuales PostgreSQL (solo si NO usas DATABASE_URL):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pricepulse
# DB_USER=pricepulse_user
# DB_PASSWORD=change_me_secure_password

# --- Scraping ---
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=8
SCRAPE_MAX_RETRIES=3
SCRAPE_RETRY_DELAY=5
SCRAPE_PRODUCTS_PER_CATEGORY=20
SCRAPE_MAX_PAGES=2

# --- Currency ---
USD_TO_MXN_RATE=17.50

# --- Pipeline ---
LOG_LEVEL=INFO

# --- Docker (ver .env.docker para referencia completa) ---
# DB_PASSWORD=change_me_secure_password
# DB_PORT_PUBLISHED=5432
# APP_PORT_PUBLISHED=8501
# SEED_DATA=true
