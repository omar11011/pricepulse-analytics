# ============================================================
# PricePulse Analytics — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment variables (contain secrets)
.env
.env.docker

# Streamlit secrets
.streamlit/secrets.toml

# Database files (generated by seed scripts)
data/*.db
demo_pricepulse.db
*.db-journal
*.db-wal
*.db-shm

# OS
.DS_Store
Thumbs.db

# Temporary files
dashboard_data.json
*.log

# Test artifacts
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
